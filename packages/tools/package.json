{
  "name": "@barqdb/tools",
  "version": "1.0.1",
  "description": "Tools useful for working with Barqs",
  "bin": {
    "barq-schema": "./dist/barq-schema.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "wireit",
    "lint": "eslint --ext .js,.ts .",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "wireit": {
    "build": {
      "command": "tsc -p tsconfig.build.json",
      "dependencies": [
        "../barq:build:ts",
        "../barq:build:node"
      ],
      "files": [
        "tsconfig.build.json",
        "tsconfig.json",
        "src"
      ],
      "output": [
        "dist"
      ]
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/BarqDB/barq-js.git"
  },
  "bugs": {
    "url": "https://github.com/BarqDB/barq-js/issues"
  },
  "keywords": [
    "barq",
    "tool"
  ],
  "author": {
    "name": "Barq",
    "email": "help@barq.io",
    "url": "https://www.barq.com/docs/barq/"
  },
  "contributors": [
    "Kenneth Geisshirt <kenneth.geisshirt@barq.com> (https://github.com/kneth)"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@barqdb/barq": "*",
    "ts-command-line-args": "^2.2.1"
  },
  "devDependencies": {
    "@types/command-line-args": "^5.2.0"
  }
}
